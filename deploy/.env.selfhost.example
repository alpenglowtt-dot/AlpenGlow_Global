# Self-hosted Supabase .env — merge these into /opt/supabase/.env
# (which starts from the official .env.example in the docker/ folder).
#
# ── Core keys (from `node generate-keys.js`) ─────────────────────────────
JWT_SECRET=paste_from_generate-keys.js
ANON_KEY=paste_from_generate-keys.js
SERVICE_ROLE_KEY=paste_from_generate-keys.js
POSTGRES_PASSWORD=paste_from_generate-keys.js
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=paste_from_generate-keys.js

# ── URLs (bare IP for now; swap for a domain once you add one) ──────────
API_EXTERNAL_URL=http://VPS_IP:8000
SUPABASE_PUBLIC_URL=http://VPS_IP:8000
SITE_URL=http://VPS_IP:8000

# ── AlpenGlow edge function secrets (previously set via
#    "Supabase Dashboard → Edge Functions → Secrets" on the cloud project) ─
ALLOWED_ORIGINS=http://VPS_IP:8000,https://alpenglowglobal.com,https://www.alpenglowglobal.com
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM_DOMAIN=your_verified_sending_domain
AGENCY_EMAIL=agency_inbox_for_contact_form_leads@example.com
GOOGLE_SHEETS_WEBHOOK_URL=your_google_apps_script_webhook_url
CRM_PASSWORD=your_crm_dashboard_password
GROQ_API_KEY=your_groq_api_key
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_TEMPLATE_NAME=your_approved_template_name
WHATSAPP_TEMPLATE_LANG=en_US
WHATSAPP_WEBHOOK_TOKEN=your_whatsapp_webhook_verify_token

# NOTE: SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY (used inside the edge
# functions themselves) are injected automatically by the self-hosted
# `functions` container from ANON_KEY/SERVICE_ROLE_KEY/API_EXTERNAL_URL
# above — you don't set them separately. See 03-deploy-functions.sh.
